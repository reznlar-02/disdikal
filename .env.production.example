# Template environment production — SALIN ke .env di server, lalu isi setiap
# nilai bertanda GANTI_INI. Jangan pernah commit file .env yang sudah terisi.
# Lihat checklist deployment untuk urutan langkahnya.

APP_NAME="E-Questioner DISDIKAL"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://GANTI_INI.contoh-domain.mil.id

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# LOG_LEVEL=debug berisik dan bisa membocorkan data sensitif ke log file.
LOG_CHANNEL=daily
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

# Jangan pakai root/password kosong seperti di Laragon lokal — buat user
# MySQL khusus dengan akses terbatas ke database ini saja.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sk_disdikal_laravel
DB_USERNAME=GANTI_INI
DB_PASSWORD=GANTI_INI

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Wajib true setelah HTTPS aktif (Fase 4) — cookie session hanya lewat koneksi terenkripsi.
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Dashboard Cloudflare Turnstile: tambahkan domain production ke allowlist
# hostname widget ini sebelum deploy, atau widget gagal muncul untuk pengunjung asli.
TURNSTILE_SITE_KEY=GANTI_INI
TURNSTILE_SECRET_KEY=GANTI_INI

VITE_APP_NAME="${APP_NAME}"
